var h;
var r = 1;
var s = 1;
var d;
var p = 1;
var q = 1;
var b = FALSE;

process INITIALISATION() =
    h := ∅;
    r := 1;
    s := 1;
    d :∈ D;
    p := 1;
    q := 1;
    b := FALSE;

process final() =
    if (r = n + 1 && b = FALSE) {
        b := TRUE;
    };

process receive() =
    if (p ≠ q) {
        h(r) := d;
        r := r + 1;
        q := 1 - q;
    };

process send() =
    if (p = q && s ≠ n + 1 && p = parity(s) && q = parity(r)) {
        d := f(s);
        s := s + 1;
        p := 1 - p;
    };

process System() =
    INITIALISATION() ||| final() ||| receive() ||| send();

#assert System() deadlockfree;
